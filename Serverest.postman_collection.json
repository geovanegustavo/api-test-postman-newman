    {
      "name": "2. Usuário",
      "item": [
        {
          "name": "Cenários de sucesso - Administrador",
          "item": [
            {
              "name": "Listar usuários cadastrados",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "// Extrair o corpo da resposta JSON\r",
                      "const resposta = pm.response.json();\r",
                      "\r",
                      "// Teste principal de autenticação\r",
                      "pm.test(\"Deve listar usuários da base\", () => {\r",
                      "    // OBSERVAÇÃO: A API do ServeRest não permite filtrar a lista por tamanho na URL\r",
                      "    // Este é o motivo deste teste listar todos os usuários\r",
                      "    // A lista de usuários é limpa a cada 10 minutos\r",
                      "\r",
                      "    // Verifica se o status HTTP é 200\r",
                      "    pm.response.to.have.status(200);\r",
                      "\r",
                      "    // Verifica se a quantidade de usuários retornada é igual ao tamanho do array de usuários\r",
                      "    pm.expect(resposta.quantidade).to.eql(resposta.usuarios.length);\r",
                      "\r",
                      "    // Verifica se a quantidade de usuários é maior que zero e se o array de usuários é um array válido\r",
                      "    pm.expect(resposta.quantidade).to.be.greaterThan(0);\r",
                      "\r",
                      "    // Verifica se o array de usuários é um array válido e não vazio\r",
                      "    pm.expect(resposta.usuarios).to.be.an('array');\r",
                      "});\r",
                      "\r",
                      "// Definição do JSON Schema esperado\r",
                      "const schema = {\r",
                      "    \"type\": \"object\",\r",
                      "    \"properties\": {\r",
                      "        \"quantidade\": { \"type\": \"number\" },\r",
                      "        \"usuarios\": {\r",
                      "            \"type\": \"array\",\r",
                      "            \"items\": {\r",
                      "                \"type\": \"object\",\r",
                      "                \"properties\": {\r",
                      "                    \"nome\": { \"type\": \"string\" },\r",
                      "                    \"email\": { \"type\": \"string\" },\r",
                      "                    \"password\": { \"type\": \"string\" },\r",
                      "                    \"administrador\": { \"type\": \"string\" }, // O ServeRest envia como string \"true\"/\"false\"\r",
                      "                    \"_id\": { \"type\": \"string\" }\r",
                      "                },\r",
                      "                // Chaves obrigatórias que todo usuário listado precisa retornar\r",
                      "                \"required\": [\"nome\", \"email\", \"password\", \"administrador\", \"_id\"]\r",
                      "            }\r",
                      "        }\r",
                      "    },\r",
                      "    \"required\": [\"quantidade\", \"usuarios\"]\r",
                      "};\r",
                      "\r",
                      "// Instanciar o validador AJV\r",
                      "const Ajv = require(\"ajv\");\r",
                      "const ajv = new Ajv({ allErrors: true }); // mostra todos os erros, não apenas o primeiro\r",
                      "\r",
                      "// Teste de contrato do JSON Schema\r",
                      "pm.test(\"Contrato do JSON Schema está correto\", () => {\r",
                      "    const respostaJson = pm.response.json();\r",
                      "    const valid = ajv.validate(schema, respostaJson);\r",
                      "\r",
                      "    // Se falhar, exibe os erros detalhados no console\r",
                      "    if (!valid) {\r",
                      "        console.log(\"Erros de validação:\", ajv.errors);\r",
                      "    }\r",
                      "\r",
                      "    pm.expect(valid, \"Schema inválido\").to.be.true;\r",
                      "});\r",
                      "\r",
                      ""
                    ],
                    "type": "text/javascript",
                    "packages": {},
                    "requests": {}
                  }
                }
              ],
              "protocolProfileBehavior": {
                "disableBodyPruning": true
              },
              "request": {
                "method": "GET",
                "header": [],
                "body": {
                  "mode": "raw",
                  "raw": ""
                },
                "url": {
