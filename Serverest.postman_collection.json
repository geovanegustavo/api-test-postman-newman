            {
              "name": "Cadastrar usuário administrador",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "// Extrair o corpo da resposta JSON\r",
                      "const resposta = pm.response.json();\r",
                      "\r",
                      "// Extrai o id do usuário do JSON de resposta\r",
                      "const rawId = resposta._id;\r",
                      "\r",
                      "// Salvar o id na variável de ambiente da coleção\r",
                      "pm.collectionVariables.set(\"idUsuario\", rawId);\r",
                      "\r",
                      "// Teste principal de autenticação\r",
                      "pm.test(\"Deve cadastrar um usuário administrador com credenciais válidas\", () => {\r",
                      "    // Verifica se o status HTTP é 201\r",
                      "    pm.response.to.have.status(201);\r",
                      "\r",
                      "    // Confirma que a mensagem indica sucesso\r",
                      "    pm.expect(resposta.message).to.eql(\"Cadastro realizado com sucesso\");\r",
                      "    console.log(resposta.message);\r",
                      "\r",
                      "    // Confirma que o id do usuário não está vazia e não nula\r",
                      "    pm.expect(rawId).to.be.not.null;\r",
                      "\r",
                      "    // Confirma que o token é uma string não vazia\r",
                      "    pm.expect(rawId).to.be.a(\"string\").and.to.have.length.greaterThan(0);\r",
                      "});\r",
                      "\r",
                      "// Definição do JSON Schema esperado\r",
                      "const schema = {\r",
                      "    type: \"object\",\r",
                      "    properties: {\r",
                      "        message: { type: \"string\" },\r",
                      "        _id: { type: \"string\" }\r",
                      "    },\r",
                      "    required: [\"message\", \"_id\"]\r",
                      "};\r",
                      "\r",
                      "// Instanciar o validador AJV\r",
                      "const Ajv = require(\"ajv\");\r",
                      "const ajv = new Ajv({ allErrors: true }); // mostra todos os erros, não apenas o primeiro\r",
                      "\r",
                      "// Teste de contrato do JSON Schema\r",
                      "pm.test(\"Contrato do JSON Schema está correto\", () => {\r",
                      "    const respostaJson = pm.response.json();\r",
                      "    const valid = ajv.validate(schema, respostaJson);\r",
                      "\r",
                      "    // Se falhar, exibe os erros detalhados no console\r",
                      "    if (!valid) {\r",
                      "        console.log(\"Erros de validação:\", ajv.errors);\r",
                      "    }\r",
                      "\r",
                      "    pm.expect(valid, \"Schema inválido\").to.be.true;\r",
                      "});\r",
                      "\r",
                      "pm.collectionVariables.unset(\"nomeCompleto\");"
                    ],
                    "type": "text/javascript",
                    "packages": {},
                    "requests": {}
                  }
                },
                {
                  "listen": "prerequest",
                  "script": {
                    "exec": [
                      "function primeiroNome () {\r",
                      "    const firstName = [\"Miguel\", \"João\", \"Pedro\", \"Maria\", \"Ana\", \"Fernanda\", \"Rafael\", \"Juliana\", \"Lucas\", \r",
                      "    \"Camila\", \"Rosana\", \"Misael\", \"Joaquim\", \"Francisco\", \"Fernando\", \"Bruno\", \"Amanda\"];\r",
                      "    const randomItem = firstName[Math.floor(Math.random() * firstName.length)];\r",
                      "    return randomItem;\r",
                      "}\r",
                      "\r",
                      "function ultimoNome () {\r",
                      "    const lastName = [\"Santos\", \"Oliveira\", \"Costa\", \"Silva\", \"Ferreira\", \"Pereira\", \"Rodrigues\", \"Martins\", \r",
                      "    \"da Silva\", \"dos Santos\", \"Almeida\", \"Barros\", \"Gomes\", \"Carvalho\", \"Lima\", \"Rocha\", \"Nunes\", \"Farias\", \"Melo\"];\r",
                      "    const randomItem = lastName[Math.floor(Math.random() * lastName.length)];\r",
                      "    return randomItem;\r",
                      "}\r",
                      "\r",
                      "const nomeCompleto = `${primeiroNome()} ${ultimoNome()}`;\r",
                      "\r",
                      "pm.collectionVariables.set(\"nomeCompleto\", nomeCompleto);\r",
                      "\r",
                      "// Função para gerar string aleatória\r",
                      "function randomString(length) {\r",
                      "    const chars = 'abcdefghijklmnopqrstuvwxyz0123456789';\r",
                      "    let result = '';\r",
                      "    for (let i = 0; i < length; i++) {\r",
                      "        result += chars.charAt(Math.floor(Math.random() * chars.length));\r",
                      "    }\r",
                      "    return result;\r",
                      "}\r",
                      "\r",
                      "// Monta e-mail aleatório\r",
                      "let email = randomString(8) + \"@qa.com.br\";\r",
                      "pm.collectionVariables.set(\"emailAleatorio\", email);\r",
                      "\r",
                      "console.log(\"Nome completo gerado:\", nomeCompleto);\r",
                      "console.log(\"Email gerado:\", pm.collectionVariables.get(\"emailAleatorio\"));"
                    ],
                    "type": "text/javascript",
                    "packages": {},
                    "requests": {}
                  }
                }
              ],
              "request": {
                "method": "POST",
                "header": [],
                "body": {
                  "mode": "raw",
                  "raw": "{\r\n  \"nome\": \"{{nomeCompleto}}\",\r\n  \"email\": \"{{emailAleatorio}}\",\r\n  \"password\": \"teste\",\r\n  \"administrador\": \"true\"\r\n}",
