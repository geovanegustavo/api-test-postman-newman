                      "// Teste de contrato do JSON Schema\r",
                      "pm.test(\"Contrato do JSON Schema está correto\", () => {\r",
                      "    const respostaJson = pm.response.json();\r",
                      "    const valid = ajv.validate(schema, respostaJson);\r",
                      "\r",
                      "    // Se falhar, exibe os erros detalhados no console\r",
                      "    if (!valid) {\r",
                      "        console.log(\"Erros de validação:\", ajv.errors);\r",
                      "    }\r",
                      "\r",
                      "    pm.expect(valid, \"Schema inválido\").to.be.true;\r",
                      "});\r",
                      "\r",
                      ""
